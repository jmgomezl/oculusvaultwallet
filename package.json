{
  "name": "oculusvault-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Non-custodial Hedera wallet inside a Telegram Mini App — SDK + demo",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @oculusvault/sdk",
    "dev:server": "npm run dev --workspace @oculusvault/server",
    "dev:miniapp": "npm run dev --workspace @oculusvault/miniapp",
    "payin": "node scripts/payin.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
