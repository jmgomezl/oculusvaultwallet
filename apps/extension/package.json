{
  "name": "@oculusvault/extension",
  "version": "0.1.0",
  "description": "OculusVault Chrome extension — the same Telegram-anchored Hedera wallet, on desktop",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "zip": "cd dist && zip -qr ../oculusvault-extension.zip . && cd .. && ls -la oculusvault-extension.zip",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oculusvault/sdk": "*",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
