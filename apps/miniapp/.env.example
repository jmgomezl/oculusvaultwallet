# Mini App (Vite) env. Copy to apps/miniapp/.env

# Backend base URL (the apps/server instance).
VITE_API_BASE=http://localhost:8787

# Hedera network the wallet operates on.
VITE_HEDERA_NETWORK=testnet

# Use the shared cross-app vault (one wallet across apps). Set to "false" to
# keep a per-app wallet in Telegram CloudStorage instead.
VITE_USE_SHARED_VAULT=true
