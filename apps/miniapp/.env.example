# Mini App (Vite) env. Copy to apps/miniapp/.env

# Backend base URL (the apps/server instance).
VITE_API_BASE=http://localhost:8787

# Hedera network the wallet operates on.
VITE_HEDERA_NETWORK=testnet

# Use the shared cross-app vault (one wallet across apps). Set to "false" to
# keep a per-app wallet in Telegram CloudStorage instead.
VITE_USE_SHARED_VAULT=true

# Your bot's username (no @). When set, the landing page's "Open in Telegram"
# CTAs become live t.me/<bot>/app links; when empty they show "launching soon".
VITE_BOT_USERNAME=

# Chrome Web Store listing URL. When set, the landing page's "Add to Chrome"
# CTA goes live; when empty it shows "in Web Store review".
VITE_CWS_URL=

# WalletConnect (Reown) project id from cloud.reown.com — free tier is fine.
# When set, the wallet's "Connect to apps" card goes live (pair with any
# Hedera dApp over HIP-820); when empty it shows "coming soon".
VITE_WC_PROJECT_ID=

# Dev only (put it in .env.development, which is gitignored): render the wallet
# UI in a plain browser instead of the landing page. Never set in production.
# VITE_FORCE_WALLET=true
