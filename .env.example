# ─────────────────────────────────────────────────────────────────────────
# hedera-telegram-wallet — example env. Copy to .env and fill in.
# Used by the backend server and the scripts/payin.mjs "machine" simulator.
# The Mini App frontend uses apps/miniapp/.env (VITE_* vars).
# ─────────────────────────────────────────────────────────────────────────

# Which Hedera network everything targets.
HEDERA_NETWORK=testnet

# --- Backend (apps/server) ---
PORT=8787

# BotFather token for your bot. Used ONLY to verify Telegram initData (HMAC).
# It is never sent to the client and never stored alongside keys.
TELEGRAM_BOT_TOKEN=PLACEHOLDER_BOT_TOKEN

# Secret used to sign session JWTs. Generate a strong random value in prod:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-only-change-me
SESSION_TTL_SECONDS=3600

# Reject initData older than this many seconds (replay protection).
INITDATA_MAX_AGE_SECONDS=86400

# Allow the Mini App to run in a plain browser with a fake user. DEV ONLY.
# Leave false/unset in production — it bypasses initData verification.
ALLOW_DEV_AUTH=true

# CORS origin for the Mini App (use your real Mini App URL in prod).
CORS_ORIGIN=*

# --- Pay-in script (scripts/payin.mjs) — the "machine" ---
# A funded testnet account. Get one (and HBAR) at https://portal.hedera.com/
# Use the ECDSA key so it matches the wallet's secp256k1 model.
OPERATOR_ID=0.0.xxxxxxx
OPERATOR_KEY=PLACEHOLDER_OPERATOR_KEY
